generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  BANNED
}

enum BookFormat {
  TXT
  EPUB
  MOBI
  PDF
}

enum BookLanguage {
  CHINESE
  ENGLISH
  JAPANESE
  KOREAN
  RUSSIAN
  GERMAN
  SPANISH
  FRENCH
  UNKNOWN
}

enum TranslationStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  NEEDS_REVIEW
  FAILED
  CANCELED
}

enum ChapterStatus {
  ACTIVE
  SKIPPED
  TOO_LONG
  TOO_SHORT
  SUSPECTED_TOC
  GARBLED
}

enum TaskStatus {
  PENDING
  EXTRACTING_TERMS
  QUEUED
  TRANSLATING
  QUALITY_CHECKING
  COMPLETED
  NEEDS_REVIEW
  FAILED
  CANCELED
}

enum LedgerType {
  GRANT
  HOLD
  CHARGE
  RELEASE
  MANUAL_ADJUSTMENT
  REFUND
}

enum TermType {
  PERSON
  PLACE
  ORGANIZATION
  RACE
  SKILL
  ITEM
  TITLE
  ADDRESS
  SETTING
  OTHER
}

enum NoteTargetType {
  FREEFORM
  ORIGINAL_BOOK
  CHAPTER
  TRANSLATED_BOOK
}

enum ImportKind {
  VOCABULARY
  SENTENCE
  NOTE
  READING
}

enum ImportBatchStatus {
  COMPLETED
  PARTIAL
}

model UserProfile {
  id                       String                    @id @default(uuid()) @db.Uuid
  phone                    String                    @unique
  displayName              String?
  role                     UserRole                  @default(USER)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  lastLoginAt              DateTime?
  balance                  AccountBalance?
  originalBooks            OriginalBook[]
  translatedBooks          TranslatedBook[]
  ledgers                  BalanceLedger[]
  holds                    BalanceHold[]
  vocabularyItems          VocabularyItem[]
  sentenceItems            SentenceItem[]
  rateLimits               AiRateLimit[]
  studyNotes               StudyNote[]
  readingStates            ReadingState[]
  storageCleanupTasks      StorageCleanupTask[]
  translationBatchReceipts TranslationBatchReceipt[]
  translationRetryReceipts TranslationRetryReceipt[]
  importBatches            ImportBatch[]
  importItems              ImportItem[]

  @@index([role])
}

model AccountBalance {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @unique @db.Uuid
  available    Decimal     @default(0) @db.Decimal(10, 2)
  frozen       Decimal     @default(0) @db.Decimal(10, 2)
  freeChapters Int         @default(5)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BalanceLedger {
  /// The authoritative migration enforces one HOLD/CHARGE/RELEASE row per hold and validates hold terminal state, amount, task, and ownership.
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  type        LedgerType
  amount      Decimal          @db.Decimal(10, 2)
  description String?
  taskId      String?          @db.Uuid
  holdId      String?          @db.Uuid
  createdAt   DateTime         @default(now())
  user        UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task        TranslationTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  hold        BalanceHold?     @relation(fields: [holdId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([type])
}

model BalanceHold {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  taskId     String?          @db.Uuid
  /// Each execution attempt owns an immutable hold; expired/retried attempts create new audit rows.
  attemptId  String           @db.Uuid
  amount     Decimal          @db.Decimal(10, 2)
  freeUnits  Int              @default(0)
  releasedAt DateTime?
  chargedAt  DateTime?
  createdAt  DateTime         @default(now())
  user       UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task       TranslationTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  ledgers    BalanceLedger[]

  @@unique([taskId, attemptId])
  @@index([userId, createdAt])
}

model OriginalBook {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  title           String
  author          String?
  sourceLanguage  BookLanguage     @default(UNKNOWN)
  format          BookFormat
  fileSizeBytes   Int
  /// Supabase migration enforces the fixed owner-bound `<userId>/<bookId>/original.txt` path; preserve its raw CHECK in drift gates.
  storagePath     String
  chapterCount    Int              @default(0)
  uploadedAt      DateTime         @default(now())
  lastOpenedAt    DateTime?
  readingProgress String?
  user            UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapters        Chapter[]
  translations    TranslatedBook[]
  terms           Term[]
  vocabularyItems VocabularyItem[]
  sentenceItems   SentenceItem[]
  readingStates   ReadingState[]
  studyNotes      StudyNote[]

  @@index([userId, uploadedAt])
}

model Chapter {
  id                 String              @id @default(uuid()) @db.Uuid
  originalBookId     String              @db.Uuid
  index              Int
  title              String
  content            String
  wordCount          Int
  status             ChapterStatus       @default(ACTIVE)
  isSkipped          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  originalBook       OriginalBook        @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  translatedChapters TranslatedChapter[]
  tasks              TranslationTask[]
  vocabularyItems    VocabularyItem[]
  sentenceItems      SentenceItem[]
  readingStates      ReadingState[]
  studyNotes         StudyNote[]

  @@unique([originalBookId, index])
  @@index([originalBookId, status])
}

model TranslatedBook {
  id                 String              @id @default(uuid()) @db.Uuid
  userId             String              @db.Uuid
  originalBookId     String              @db.Uuid
  title              String
  targetLanguage     BookLanguage
  status             TranslationStatus   @default(DRAFT)
  progressPercent    Int                 @default(0)
  completedChapters  Int                 @default(0)
  failedChapters     Int                 @default(0)
  webSearchTerms     Boolean             @default(false)
  createdAt          DateTime            @default(now())
  lastReadAt         DateTime?
  readingProgress    String?
  user               UserProfile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalBook       OriginalBook        @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  translatedChapters TranslatedChapter[]
  tasks              TranslationTask[]
  terms              Term[]
  readingStates      ReadingState[]
  studyNotes         StudyNote[]

  @@unique([userId, originalBookId, targetLanguage])
  @@index([userId, createdAt])
  @@index([originalBookId, targetLanguage])
}

model TranslatedChapter {
  id               String         @id @default(uuid()) @db.Uuid
  translatedBookId String         @db.Uuid
  chapterId        String         @db.Uuid
  title            String
  content          String
  qualityPassed    Boolean        @default(false)
  providerName     String?
  modelName        String?
  inputTokens      Int?
  outputTokens     Int?
  wordCount        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  translatedBook   TranslatedBook @relation(fields: [translatedBookId], references: [id], onDelete: Cascade)
  chapter          Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([translatedBookId, chapterId])
  @@index([translatedBookId])
}

model TranslationTask {
  id                      String                    @id @default(uuid()) @db.Uuid
  translatedBookId        String                    @db.Uuid
  chapterId               String                    @db.Uuid
  status                  TaskStatus                @default(PENDING)
  estimatedCost           Decimal                   @db.Decimal(10, 2)
  retryCount              Int                       @default(0)
  /// Lease token used by server-side compare-and-swap completion. Never expose this field in browser DTOs.
  attemptId               String?                   @db.Uuid
  attemptStartedAt        DateTime?
  attemptExpiresAt        DateTime?
  /// Validated JSON segment checkpoint; the SQL migration enforces lease/checkpoint consistency.
  translatedSegments      Json                      @default("[]")
  nextSegmentIndex        Int                       @default(0)
  checkpointProvider      String?
  checkpointModel         String?
  accumulatedInputTokens  Int                       @default(0)
  accumulatedOutputTokens Int                       @default(0)
  lastHeartbeatAt         DateTime?
  /// Per-batch execution token; prevents concurrent provider calls for one checkpoint index.
  batchExecutionId        String?                   @db.Uuid
  batchExecutionExpiresAt DateTime?
  batchExecutionIndex     Int?
  lastBatchExecutionId    String?                   @db.Uuid
  errorCode               String?
  errorMessage            String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  translatedBook          TranslatedBook            @relation(fields: [translatedBookId], references: [id], onDelete: Cascade)
  chapter                 Chapter                   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  balanceHolds            BalanceHold[]
  ledgers                 BalanceLedger[]
  batchReceipts           TranslationBatchReceipt[]
  retryReceipts           TranslationRetryReceipt[]

  @@unique([translatedBookId, chapterId])
  @@index([translatedBookId, status])
  @@index([status, attemptExpiresAt])
  @@index([chapterId])
  @@index([createdAt])
}

model TranslationBatchReceipt {
  /// Immutable provider execution receipt. The authoritative migration blocks UPDATE/DELETE.
  executionId       String          @id @db.Uuid
  userId            String          @db.Uuid
  taskId            String          @db.Uuid
  attemptId         String          @db.Uuid
  startSegmentIndex Int
  endSegmentIndex   Int
  outcome           String
  errorCode         String?
  createdAt         DateTime        @default(now())
  user              UserProfile     @relation(fields: [userId], references: [id], onDelete: Restrict)
  task              TranslationTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
}

model TranslationRetryReceipt {
  /// Immutable retry audit evidence used to reconcile an ambiguous retry commit.
  retryExecutionId String          @id @db.Uuid
  userId           String          @db.Uuid
  taskId           String          @db.Uuid
  fromRetryCount   Int
  toRetryCount     Int
  resetCheckpoint  Boolean
  createdAt        DateTime        @default(now())
  user             UserProfile     @relation(fields: [userId], references: [id], onDelete: Restrict)
  task             TranslationTask @relation(fields: [taskId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([taskId, createdAt])
}

model Term {
  id               String          @id @default(uuid()) @db.Uuid
  originalBookId   String          @db.Uuid
  translatedBookId String?         @db.Uuid
  type             TermType        @default(OTHER)
  sourceText       String
  translatedText   String
  isUserLocked     Boolean         @default(false)
  confidence       Int             @default(0)
  sourceNote       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  originalBook     OriginalBook    @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  translatedBook   TranslatedBook? @relation(fields: [translatedBookId], references: [id], onDelete: Cascade)

  @@unique([originalBookId, translatedBookId, sourceText])
  @@index([originalBookId, type])
}

model VocabularyItem {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  originalBookId String       @db.Uuid
  chapterId      String?      @db.Uuid
  term           String
  explanation    String
  contextualMean String?
  sourceSentence String?
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalBook   OriginalBook @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  chapter        Chapter?     @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@unique([userId, originalBookId, term])
  @@index([userId, createdAt])
  @@index([originalBookId])
}

model SentenceItem {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  originalBookId String       @db.Uuid
  chapterId      String?      @db.Uuid
  originalText   String
  translatedText String?
  explanation    String?
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalBook   OriginalBook @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  chapter        Chapter?     @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@unique([userId, originalBookId, originalText])
  @@index([userId, createdAt])
  @@index([originalBookId])
}

model AiRateLimit {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @db.Uuid
  scope     String
  count     Int         @default(0)
  windowKey String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, windowKey])
  @@index([userId, updatedAt])
}

model StudyNote {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @db.Uuid
  title            String
  content          String
  /// The authoritative migration enforces that exactly the target selected by targetType is populated and owner-bound.
  targetType       NoteTargetType  @default(FREEFORM)
  originalBookId   String?         @db.Uuid
  chapterId        String?         @db.Uuid
  translatedBookId String?         @db.Uuid
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalBook     OriginalBook?   @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  chapter          Chapter?        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  translatedBook   TranslatedBook? @relation(fields: [translatedBookId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([originalBookId])
  @@index([chapterId])
  @@index([translatedBookId])
}

model ReadingState {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @db.Uuid
  /// Supabase migration enforces XOR and partial uniqueness for originalBookId and translatedBookId.
  originalBookId   String?         @db.Uuid
  /// Supabase migration enforces XOR and partial uniqueness for originalBookId and translatedBookId.
  translatedBookId String?         @db.Uuid
  chapterId        String?         @db.Uuid
  /// Supabase migration enforces paragraphIndex >= 0; do not replace its raw constraints with Prisma-generated migrations.
  paragraphIndex   Int             @default(0)
  version          Int             @default(0)
  settings         Json?
  updatedAt        DateTime        @updatedAt
  user             UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalBook     OriginalBook?   @relation(fields: [originalBookId], references: [id], onDelete: Cascade)
  translatedBook   TranslatedBook? @relation(fields: [translatedBookId], references: [id], onDelete: Cascade)
  chapter          Chapter?        @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([userId, originalBookId])
  @@index([userId, translatedBookId])
  @@index([userId, updatedAt])
  @@index([chapterId])
}

model StorageCleanupTask {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  bucket        String
  objectPath    String
  reason        String
  attempts      Int         @default(0)
  nextAttemptAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([bucket, objectPath])
  @@index([userId, nextAttemptAt])
}

model ImportBatch {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  manifestId      String            @db.Uuid
  manifestVersion Int
  status          ImportBatchStatus
  itemCount       Int
  createdCount    Int
  skippedCount    Int
  conflictCount   Int
  errorCount      Int
  startedAt       DateTime
  completedAt     DateTime
  user            UserProfile       @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, manifestId])
  @@index([userId, completedAt])
}

model ImportItem {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  kind          ImportKind
  sourceId      String
  sourceVersion Int
  payloadHash   String
  targetId      String      @db.Uuid
  createdAt     DateTime    @default(now())
  user          UserProfile @relation(fields: [userId], references: [id], onDelete: Restrict)

  /// The migration validates the polymorphic targetId, makes identity immutable, and forbids UPDATE/DELETE/TRUNCATE.
  @@unique([userId, kind, sourceId])
  @@index([userId, createdAt])
  @@index([kind, targetId])
}
